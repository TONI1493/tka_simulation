          {
            "id": "A",
            "text": "Fotosintesis"
          },
          {
            "id": "B",
            "text": "Kantong semar"
          },
          {
            "id": "C",
            "text": "Sundew"
          }
        ],
        "correctAnswers": [
          "B",
          "C"
        ]
