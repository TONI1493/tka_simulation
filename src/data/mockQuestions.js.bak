      { id: 12, type: 'multiple-answer', text: "Ibu membeli belanjaan sebagai berikut:\n- Beras: 2 kg\n- Tepung terigu: 500 gram\n- Mentega: 10 ons\n\nPilihlah pernyataan yang benar tentang berat belanjaan Ibu! Jawaban benar lebih dari satu.", options: [{ id: 'A', text: "Total berat belanjaan Ibu adalah 3,5 kg." }, { id: 'B', text: "Berat mentega sama dengan berat 1 kg beras." }, { id: 'C', text: "Tepung terigu adalah belanjaan yang paling berat." }], correctAnswers: ['A', 'B'] },
      { id: 13, type: 'multiple-choice', text: "Adit belajar mulai pukul 18.30 dan selesai pukul 20.15. Lama waktu Adit belajar adalah ....", options: [{ id: 'A', text: "1 jam 15 menit" }, { id: 'B', text: "1 jam 30 menit" }, { id: 'C', text: "1 jam 45 menit" }, { id: 'D', text: "2 jam 15 menit" }], correctAnswer: 'C' },
      { id: 14, type: 'multiple-choice', text: "Sebuah wadah berisi 2.500 ml air. Volume air tersebut sama dengan ....", options: [{ id: 'A', text: "0,25 liter" }, { id: 'B', text: "2,5 liter" }, { id: 'C', text: "25 liter" }, { id: 'D', text: "250 liter" }], correctAnswer: 'B' },
      { id: 15, type: 'multiple-choice', text: "Sebuah bus melaju dengan kecepatan rata-rata 60 km/jam. Jika bus tersebut menempuh jarak 150 km, maka waktu yang diperlukan adalah ....", options: [{ id: 'A', text: "2 jam" }, { id: 'B', text: "2 jam 30 menit" }, { id: 'C', text: "3 jam" }, { id: 'D', text: "3 jam 30 menit" }], correctAnswer: 'B' },
      { id: 16, type: 'multiple-choice', text: "Sebuah keran air dapat mengisi ember bervolume 20 liter dalam waktu 4 menit. Debit air dari keran tersebut adalah ....", options: [{ id: 'A', text: "5 liter/menit" }, { id: 'B', text: "16 liter/menit" }, { id: 'C', text: "24 liter/menit" }, { id: 'D', text: "80 liter/menit" }], correctAnswer: 'A' },
      { id: 17, type: 'true-false-statements', text: "Sebuah taman berbentuk persegi panjang dengan panjang 25 meter dan lebar 12 meter. Tentukan Benar atau Salah untuk pernyataan berikut!", statements: [{ id: 'A', text: "Luas taman tersebut adalah 300 meter persegi.", correctAnswer: "benar" }, { id: 'B', text: "Keliling taman tersebut adalah 37 meter.", correctAnswer: "salah" }, { id: 'C', text: "Jika dipasang pagar di sekelilingnya, panjang pagar yang dibutuhkan adalah 74 meter.", correctAnswer: "benar" }] },
      { id: 18, type: 'multiple-choice', text: "Perhatikan deskripsi ciri-ciri segitiga berikut!\n\n- Segitiga A: Ketiga sisinya sama panjang.\n- Segitiga B: Memiliki dua sisi yang sama panjang.\n- Segitiga C: Salah satu sudutnya besarnya 90 derajat.\n- Segitiga D: Ketiga sisi dan sudutnya tidak ada yang sama.\n\nBerdasarkan deskripsi tersebut, manakah yang merupakan segitiga sama kaki?", options: [{ id: 'A', text: "Segitiga A" }, { id: 'B', text: "Segitiga B" }, { id: 'C', text: "Segitiga C" }, { id: 'D', text: "Segitiga D" }], correctAnswer: 'B' },
      { id: 19, type: 'multiple-choice', text: "Sebuah roda memiliki diameter 70 cm. Keliling roda tersebut adalah .... (gunakan pi = 22/7)", options: [{ id: 'A', text: "110 cm" }, { id: 'B', text: "220 cm" }, { id: 'C', text: "440 cm" }, { id: 'D', text: "1.540 cm" }], correctAnswer: 'B' },
      { id: 20, type: 'multiple-choice', text: "Beni memiliki 3 baju (merah, biru, hijau) dan 2 celana (hitam, putih). Banyak variasi pasangan baju dan celana yang dapat digunakan Beni adalah ....", options: [{ id: 'A', text: "5 pasang" }, { id: 'B', text: "6 pasang" }, { id: 'C', text: "8 pasang" }, { id: 'D', text: "10 pasang" }], correctAnswer: 'B' },
      { id: 21, type: 'multiple-answer', text: "Perhatikan sifat-sifat bangun ruang berikut! Manakah yang merupakan sifat dari sebuah tabung? Jawaban benar lebih dari satu.", options: [{ id: 'A', text: "Memiliki 3 sisi (2 lingkaran, 1 selimut)." }, { id: 'B', text: "Memiliki 2 rusuk lengkung." }, { id: 'C', text: "Memiliki satu titik puncak yang lancip." }], correctAnswers: ['A', 'B'] },
      { id: 22, type: 'multiple-choice', text: "- Opsi A: Terdiri dari 5 persegi yang disusun memanjang.\n- Opsi B: Terdiri dari 6 persegi yang disusun membentuk pola 'T'.\n- Opsi C: Terdiri dari 4 persegi dan 2 segitiga.\n- Opsi D: Terdiri dari 6 persegi yang disusun membentuk satu baris panjang.\n\nManakah yang merupakan deskripsi jaring-jaring kubus yang benar?", options: [{ id: 'A', text: "Opsi A" }, { id: 'B', text: "Opsi B" }, { id: 'C', text: "Opsi C" }, { id: 'D', text: "Opsi D" }], correctAnswer: 'B' },
      { id: 23, type: 'multiple-choice', text: "Sebuah balok memiliki ukuran:\n- Panjang: 15 cm\n- Lebar: 10 cm\n- Tinggi: 8 cm\n\nVolume balok tersebut adalah ....", options: [{ id: 'A', text: "1.000 cm3" }, { id: 'B', text: "1.200 cm3" }, { id: 'C', text: "1.500 cm3" }, { id: 'D', text: "1.800 cm3" }], correctAnswer: 'B' },
      { id: 24, type: 'true-false-statements', text: "Perhatikan pernyataan tentang simetri berikut! Tentukan Benar atau Salah!", statements: [{ id: 'A', text: "Persegi memiliki 4 simetri lipat.", correctAnswer: "benar" }, { id: 'B', text: "Lingkaran memiliki jumlah simetri lipat yang tak terhingga.", correctAnswer: "benar" }, { id: 'C', text: "Segitiga sembarang memiliki 1 simetri lipat.", correctAnswer: "salah" }] },
      { id: 25, type: 'multiple-choice', text: "Diberikan tabel nilai hasil ulangan Matematika:\n\n| Nilai | Jumlah Siswa |\n|---|---|\n| 70 | 5 siswa |\n| 80 | 10 siswa |\n| 90 | 8 siswa |\n| 100 | 2 siswa |\n\nBanyak siswa yang mendapatkan nilai lebih dari 80 adalah ....", options: [{ id: 'A', text: "8 siswa" }, { id: 'B', text: "10 siswa" }, { id: 'C', text: "18 siswa" }, { id: 'D', text: "25 siswa" }], correctAnswer: 'B' },
      { id: 26, type: 'true-false-statements', text: "Perhatikan data hasil penjualan buah berikut:\n\n| Jenis Buah | Berat Terjual |\n|---|---|\n| Jeruk | 20 kg |\n| Apel | 15 kg |\n| Mangga | 25 kg |\n| Melon | 10 kg |\n\nTentukan Benar atau Salah untuk pernyataan berikut!", statements: [{ id: 'A', text: "Buah yang paling banyak terjual adalah Mangga.", correctAnswer: "benar" }, { id: 'B', text: "Selisih penjualan Jeruk dan Melon adalah 5 kg.", correctAnswer: "salah" }, { id: 'C', text: "Total seluruh buah yang terjual adalah 70 kg.", correctAnswer: "benar" }] },
      { id: 27, type: 'multiple-choice', text: "Data berikut menunjukkan suhu udara pada beberapa waktu:\n\n- Pukul 06.00: 24 derajat C\n- Pukul 08.00: 26 derajat C\n- Pukul 10.00: 29 derajat C\n- Pukul 12.00: 32 derajat C\n\nKenaikan suhu tertinggi terjadi pada selang waktu ....", options: [{ id: 'A', text: "06.00 - 08.00" }, { id: 'B', text: "08.00 - 10.00" }, { id: 'C', text: "10.00 - 12.00" }, { id: 'D', text: "06.00 - 10.00" }], correctAnswer: 'C' },
      { id: 28, type: 'multiple-choice', text: "Perhatikan piktogram jumlah buku di perpustakaan berikut:\n\n| Jenis Buku | Jumlah (1 icon = 10 buku) |\n|---|---|\n| Cerita | [][][][][] |\n| Pelajaran | [][][] |\n| Majalah | [][] |\n\nBerdasarkan data tersebut, berapakah jumlah buku cerita?", options: [{ id: 'A', text: "5 buku" }, { id: 'B', text: "15 buku" }, { id: 'C', text: "50 buku" }, { id: 'D', text: "100 buku" }], correctAnswer: 'C' },
      { id: 29, type: 'multiple-choice', text: "Nilai ulangan matematika Tino adalah 80, 75, 90, 85, dan 70. Rata-rata nilai ulangan Tino adalah ....", options: [{ id: 'A', text: "78" }, { id: 'B', text: "80" }, { id: 'C', text: "82" }, { id: 'D', text: "85" }], correctAnswer: 'B' },
      { id: 30, type: 'multiple-choice', text: "Data hobi siswa kelas 6 adalah sebagai berikut:\n\n- Renang: 10 siswa\n- Catur: 4 siswa\n- Basket: 6 siswa\n- Musik: 5 siswa\n\nModus dari data hobi tersebut adalah ....", options: [{ id: 'A', text: "Renang" }, { id: 'B', text: "Catur" }, { id: 'C', text: "Basket" }, { id: 'D', text: "Musik" }], correctAnswer: 'A' }
    ],
paket3: [
        {
          "id": 1,
