          {
            "id": "A",
            "text": "Penyakit mata yang disebabkan oleh terlalu banyak membaca buku."
          },
          {
            "id": "B",
            "text": "Kondisi ketika mata terkena cahaya matahari secara langsung dalam waktu lama."
          },
          {
            "id": "C",
            "text": "Kelelahan mata akibat terlalu lama menatap layar sehingga mata menjadi kering dan terasa perih."
          },
          {
            "id": "D",
            "text": "Gangguan penglihatan permanen yang dialami oleh pengguna gadget."
          }
        ],
        "correctAnswer": "K"
      },
