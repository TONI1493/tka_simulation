            "id": "B",
            "text": "Semua makhluk punya ketakutannya masing-masing"
          },
          {
            "id": "C",
            "text": "Rasa takut tidak boleh dibiarkan menguasai diri"
          }
        ],
        "correctAnswers": [
          "B"
        ]
      },
